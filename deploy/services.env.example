# 以 GitLab 受保护的文件类型变量 DEPLOY_ENV_FILE 注入；不要提交 services.env。
# 此 Compose 文件会部署 MySQL、Nacos 与 Milvus 及所有业务服务。
SPRING_PROFILES_ACTIVE=cloud
# 业务服务统一使用 Compose 内的 mysql、nacos、milvus 服务；无需设置其地址。
APP_DB_NAME=middleware_resource_manager
APP_DB_USERNAME=root
APP_DB_PASSWORD=
GATEWAY_SIGNING_SECRET=
NACOS_NAMESPACE=
NACOS_USERNAME=nacos
NACOS_PASSWORD=nacos
NACOS_CONFIG_GROUP=DEFAULT_GROUP
NACOS_DISCOVERY_GROUP=DEFAULT_GROUP

# Nacos 服务端认证。TOKEN 须为 Base64 编码且解码后至少 32 字节。
NACOS_AUTH_ENABLE=true
NACOS_AUTH_TOKEN=
NACOS_AUTH_IDENTITY_KEY=
NACOS_AUTH_IDENTITY_VALUE=

# 所有有状态组件均使用宿主机目录挂载；部署账号必须有该目录的读写权限。
DEPLOY_DATA_DIR=/data/infra-portal

# MySQL/Nacos/Milvus 版本和端口可按环境覆盖。
MYSQL_VERSION=8.0
NACOS_VERSION=v2.3.2
MILVUS_VERSION=v2.3.4
ETCD_VERSION=v3.5.5
MINIO_VERSION=RELEASE.2023-03-20T20-16-18Z

# 按需补充服务特有配置，例如 AI_SERVICE 的 AI_API_KEY、VECTOR_HOST，
# 以及 core-service 的 ADMIN_DEFAULT_PASSWORD。此文件中的所有变量都会传入容器。
